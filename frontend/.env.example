# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# ── Solana RPC ────────────────────────────────────────────────────────────────
# Optional. Defaults to public devnet endpoint if not set.
# Get a free key: https://www.helius.dev  or  https://www.quicknode.com
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# ── Platform wallet private key ───────────────────────────────────────────────
# Base58-encoded secret key. Used ONLY for Irys/Arweave uploads (/api/upload).
# Generate: solana-keygen new --outfile platform-wallet.json --no-bip39-passphrase
# Encode:   node -e "const k=require('./platform-wallet.json');const bs58=require('bs58');console.log(bs58.encode(Buffer.from(k)))"
PRIVATE_KEY=your_base58_private_key_here
