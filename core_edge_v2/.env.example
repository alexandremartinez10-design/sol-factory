# ─── Hyperliquid Credentials ─────────────────────────────────────────────────
# SECURITY: Never commit this file. Add .env to .gitignore immediately.
HL_WALLET_ADDRESS=0xYourWalletAddressHere
HL_API_SECRET=0xYourPrivateKeyHere

# ─── Trading Mode ─────────────────────────────────────────────────────────────
# Set to "true" to use paper trading (no real orders placed).
# ALWAYS start in paper mode and run a backtest before going live.
PAPER_TRADING=true

# ─── Optional: Override default assets / timeframes ──────────────────────────
# ASSETS=BTC,ETH,SOL
# TIMEFRAMES=15m,1H,4H

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=core_edge_v2.log
