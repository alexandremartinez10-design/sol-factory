{
  "compilerOptions": {
    "target":         "es2020",
    "module":         "commonjs",
    "lib":            ["es2020"],
    "strict":         true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir":         "./dist",
    "typeRoots":      ["./node_modules/@types"],
    "types":          ["mocha", "chai", "node"]
  },
  "include": ["tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "target"]
}
